{
  "name": "@octoc2/server",
  "version": "0.1.0",
  "private": true,
  "description": "OctoC2 operator C2 controller — gRPC service, beacon registry, task queue",
  "module": "src/index.ts",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile dist/svc-server"
  },
  "dependencies": {
    "@octokit/rest": "^21.0.0",
    "@grpc/grpc-js": "^1.11.0",
    "@grpc/proto-loader": "^0.7.0",
    "libsodium-wrappers": "^0.7.15",
    "jose": "^5.9.0"
  },
  "devDependencies": {
    "@types/libsodium-wrappers": "^0.8.2",
    "@types/node": "*",
    "bun-types": "^1.3.11",
    "typescript": "*"
  }
}
