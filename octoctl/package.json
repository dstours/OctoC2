{
  "name": "@octoc2/octoctl",
  "version": "0.1.0",
  "private": true,
  "description": "octoctl — OctoC2 modern terminal operator CLI",
  "bin": {
    "octoctl": "dist/octoctl"
  },
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --compile --target=bun-linux-x64 --outfile dist/octoctl"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.0",
    "@grpc/grpc-js": "^1.11.0",
    "@octokit/rest": "^22.0.1",
    "chalk": "^5.3.0",
    "commander": "^12.1.0",
    "ink": "^5.1.0",
    "libsodium-wrappers": "^0.8.2",
    "ora": "^8.1.0",
    "react": "^18.3.0"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "bun-types": "^1.3.11",
    "typescript": "*"
  }
}
