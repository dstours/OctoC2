{
  "name": "@octoc2/implant",
  "version": "0.1.0",
  "private": true,
  "description": "OctoC2 Bun TypeScript beacon — ConnectionFactory + all tentacle channels",
  "module": "src/index.ts",
  "main": "dist/beacon.js",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun run build:linux-x64",
    "build:linux-x64": "bun build src/index.ts --compile --minify --sourcemap=none --target=bun-linux-x64 --external cpu-features --outfile dist/beacon-linux-x64",
    "build:linux-arm64": "bun build src/index.ts --compile --minify --sourcemap=none --target=bun-linux-arm64 --external cpu-features --outfile dist/beacon-linux-arm64",
    "build:windows-x64": "bun build src/index.ts --compile --minify --sourcemap=none --target=bun-windows-x64 --external cpu-features --outfile dist/beacon-windows-x64.exe",
    "build:darwin-arm64": "bun build src/index.ts --compile --minify --sourcemap=none --target=bun-darwin-arm64 --external cpu-features --outfile dist/beacon-macos-arm64",
    "build:darwin-x64": "bun build src/index.ts --compile --minify --sourcemap=none --target=bun-darwin-x64 --external cpu-features --outfile dist/beacon-macos-x64",
    "build:all": "bun run build:linux-x64 && bun run build:linux-arm64 && bun run build:windows-x64 && bun run build:darwin-arm64 && bun run build:darwin-x64",
    "test": "bun test src/__tests__",
    "test:watch": "bun test --watch src/__tests__"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.11.0",
    "@grpc/proto-loader": "^0.7.0",
    "@octokit/rest": "^21.0.0",
    "jose": "^6.2.2",
    "libsodium-wrappers": "^0.7.15",
    "protobufjs": "^8.0.1",
    "ssh2": "^1.16.0"
  },
  "devDependencies": {
    "@types/libsodium-wrappers": "^0.8.2",
    "@types/ssh2": "^1.15.0",
    "bun-types": "^1.3.11",
    "typescript": "*"
  }
}
